# ══════════════════════════════════════════════════════════════
# MAGI System — Environment Configuration
# Copy to .env and fill in your API keys
# ══════════════════════════════════════════════════════════════

# ── Provider API Keys ──
# Set at least ONE provider. OpenRouter gives access to all models via one key.

# Option A: OpenRouter (recommended — one key for all models)
OPENROUTER_API_KEY=

# Option B: Individual provider keys
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_API_KEY=

# ── Default Models ──
# Override which models each MAGI node uses.
# Format: provider/model (see LiteLLM docs for full list)
#
# Budget-friendly (OpenRouter):
#   MAGI_MELCHIOR=openrouter/deepseek/deepseek-v3.2
#   MAGI_BALTHASAR=openrouter/xiaomi/mimo-v2-pro
#   MAGI_CASPER=openrouter/minimax/minimax-m2.7
#
# Premium (direct API keys):
#   MAGI_MELCHIOR=claude-sonnet-4-6
#   MAGI_BALTHASAR=gpt-4o
#   MAGI_CASPER=gemini/gemini-2.5-pro
#
# Gemini Flash (fast + cheap, direct Google API):
#   MAGI_MELCHIOR=gemini/gemini-2.5-flash
#   MAGI_BALTHASAR=gemini/gemini-2.5-flash
#   MAGI_CASPER=gemini/gemini-2.5-flash

MAGI_MELCHIOR=openrouter/deepseek/deepseek-v3.2
MAGI_BALTHASAR=openrouter/xiaomi/mimo-v2-pro
MAGI_CASPER=openrouter/minimax/minimax-m2.7

# ── Judge Model (for semantic agreement scoring) ──
# Used by adaptive protocol to assess consensus. Should be fast + cheap.
# Default: openrouter/stepfun/step-3.5-flash:free
MAGI_JUDGE_MODEL=openrouter/stepfun/step-3.5-flash:free

# ── Dashboard ──
MAGI_DASHBOARD_HOST=0.0.0.0
MAGI_DASHBOARD_PORT=3000
